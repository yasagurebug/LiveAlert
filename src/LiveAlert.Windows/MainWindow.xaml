<Window x:Class="LiveAlert.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LiveAlert"
        Icon="Resources/LiveAlert.ico"
        Width="1180"
        Height="860"
        MinWidth="980"
        MinHeight="760"
        Background="#101010"
        Foreground="#F5F5F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="18" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18" CornerRadius="10" Background="#181818">
                <StackPanel>
                    <TextBlock FontSize="30" FontWeight="Bold" Text="{Binding AppDisplayName}" />
                    <TextBlock Margin="0,8,0,0" FontSize="14" Foreground="#D0D0D0" Text="{Binding StatusText}" />
                    <TextBlock Margin="0,4,0,0" FontSize="14" Foreground="#D0D0D0" Text="{Binding CurrentAlertText, StringFormat=現在のアラート: {0}}" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#9A9A9A" Text="{Binding ConfigPath, StringFormat=config: {0}}" />
                    <TextBlock Margin="0,14,0,0"
                               FontSize="13"
                               Foreground="#C8C8C8"
                               TextWrapping="Wrap"
                               Text="常駐中は常に YouTube を監視します。操作系メニューはタスクトレイの右クリックから開いてください。" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Padding="14" CornerRadius="10" Background="#181818">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               FontSize="18"
                               FontWeight="Bold"
                               Text="全体設定" />

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock FontWeight="Bold" Text="ポーリング間隔（秒）" />
                            <TextBox Margin="0,6,0,0" Text="{Binding PollIntervalSec, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock FontWeight="Bold" Text="最大鳴動時間（秒）" />
                            <TextBox Margin="0,6,0,0" Text="{Binding MaxAlarmDurationSec, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="0,0,12,0">
                            <TextBlock FontWeight="Bold" Text="ループ間隔（秒）" />
                            <TextBox Margin="0,6,0,0" Text="{Binding LoopIntervalSec, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="0,0,12,0">
                            <TextBlock FontWeight="Bold" Text="帯高さ（px）" />
                            <TextBox Margin="0,6,0,0" Text="{Binding BandHeightPx, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock FontWeight="Bold" Text="帯位置" />
                            <ComboBox Margin="0,6,0,0" SelectedValuePath="Content" SelectedValue="{Binding BandPosition}">
                                <ComboBoxItem Content="top" />
                                <ComboBoxItem Content="center" />
                                <ComboBoxItem Content="bottom" />
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <CheckBox Grid.Row="4"
                              Foreground="White"
                              IsChecked="{Binding WindowsAutoStart}"
                              Content="Windows起動時に自動起動する" />
                </Grid>
            </Border>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" />
                    <ColumnDefinition Width="22" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="14" CornerRadius="10" Background="#181818">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,12"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="監視対象" />
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Width="86" Margin="0,0,10,0" Padding="10,6" Background="#455A64" Foreground="White" Click="HandleAddAlertClick" Content="追加" />
                            <Button Width="86" Padding="10,6" Background="#5D4037" Foreground="White" Click="HandleRemoveAlertClick" Content="削除" />
                        </StackPanel>

                        <ListBox ItemsSource="{Binding Alerts}"
                                 SelectedItem="{Binding SelectedAlert}"
                                 Background="#202020"
                                 BorderThickness="0"
                                 Foreground="White">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" Padding="10" Background="#2A2A2A" CornerRadius="8">
                                        <TextBlock FontSize="14" Text="{Binding DisplayLabel}" />
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Padding="14" CornerRadius="10" Background="#181818">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Text="個別設定" />

                        <Grid Grid.Row="2" DataContext="{Binding SelectedAlert}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock FontWeight="Bold" Text="YouTube URL" />
                                <TextBox Margin="0,6,0,0" Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock FontWeight="Bold" Text="表示名" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="Bold" Text="メッセージ" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Message, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock FontWeight="Bold" Text="音声ファイル" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Voice, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Padding="12,6" Background="#455A64" Foreground="White" Click="HandleBrowseVoiceClick" Content="参照" />
                            </Grid>

                            <StackPanel Grid.Row="6">
                                <TextBlock FontWeight="Bold" Text="{Binding VoiceVolume, StringFormat=音声音量: {0:F0}}" />
                                <Slider Margin="0,6,0,0" Minimum="0" Maximum="100" Value="{Binding VoiceVolume}" />
                            </StackPanel>

                            <Grid Grid.Row="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock FontWeight="Bold" Text="BGM ファイル" />
                                    <TextBox Margin="0,6,0,0" Text="{Binding Bgm, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <Button Grid.Column="1" VerticalAlignment="Bottom" Padding="12,6" Background="#455A64" Foreground="White" Click="HandleBrowseBgmClick" Content="参照" />
                            </Grid>

                            <StackPanel Grid.Row="10">
                                <TextBlock FontWeight="Bold" Text="{Binding BgmVolume, StringFormat=BGM音量: {0:F0}}" />
                                <Slider Margin="0,6,0,0" Minimum="0" Maximum="100" Value="{Binding BgmVolume}" />
                            </StackPanel>

                            <Grid Grid.Row="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock FontWeight="Bold" Text="背景色" />
                                    <Button Margin="0,6,0,0"
                                            Padding="12,8"
                                            Background="{Binding BackgroundPreviewBrush}"
                                            Foreground="{Binding BackgroundPreviewTextBrush}"
                                            BorderBrush="#6C6C6C"
                                            Click="HandlePickBackgroundColorClick"
                                            Content="{Binding BackgroundColor}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="Bold" Text="文字色" />
                                    <Button Margin="0,6,0,0"
                                            Padding="12,8"
                                            Background="{Binding TextPreviewBrush}"
                                            Foreground="{Binding TextPreviewTextBrush}"
                                            BorderBrush="#6C6C6C"
                                            Click="HandlePickTextColorClick"
                                            Content="{Binding TextColor}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
