<Window x:Class="LiveAlert.Windows.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LiveAlert.Windows.Views"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Border BorderBrush="#111111"
            BorderThickness="4"
            CornerRadius="2">
        <Grid x:Name="RootGrid"
              SnapsToDevicePixels="True"
              MouseLeftButtonUp="HandleBandClicked">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.0*" />
                <RowDefinition Height="0.45*" />
                <RowDefinition Height="2.2*" />
                <RowDefinition Height="0.45*" />
                <RowDefinition Height="1.0*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{Binding BackgroundColor, RelativeSource={RelativeSource AncestorType=Window}}">
                <views:ScrollingBitmapView x:Name="TopEmergencyView" ClipToBounds="True" />
            </Border>

            <Border Grid.Row="1" Background="{Binding BackgroundColor, RelativeSource={RelativeSource AncestorType=Window}}">
                <views:ScrollingBitmapView x:Name="TopStripeView" ClipToBounds="True" />
            </Border>

            <Border Grid.Row="2" Background="{Binding BackgroundColor, RelativeSource={RelativeSource AncestorType=Window}}">
                <views:ScrollingBitmapView x:Name="CenterMessageView" ClipToBounds="True" />
            </Border>

            <Border Grid.Row="3" Background="{Binding BackgroundColor, RelativeSource={RelativeSource AncestorType=Window}}">
                <views:ScrollingBitmapView x:Name="BottomStripeView" ClipToBounds="True" />
            </Border>

            <Border Grid.Row="4" Background="{Binding BackgroundColor, RelativeSource={RelativeSource AncestorType=Window}}">
                <views:ScrollingBitmapView x:Name="BottomEmergencyView" ClipToBounds="True" />
            </Border>
        </Grid>
    </Border>
</Window>
