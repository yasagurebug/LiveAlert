<Window x:Class="LiveAlert.Windows.Views.TextViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="860"
        Height="720"
        MinWidth="680"
        MinHeight="480"
        Background="#101010"
        Foreground="#F5F5F5"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="ContentTextBox"
                 Grid.Row="0"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Background="#181818"
                 Foreground="#F5F5F5"
                 BorderBrush="#2E2E2E"
                 FontFamily="Consolas"
                 FontSize="14" />

        <Button Grid.Row="1"
                Margin="0,12,0,0"
                Padding="14,8"
                Width="120"
                HorizontalAlignment="Right"
                Background="#455A64"
                Foreground="White"
                Click="HandleCloseClick"
                Content="閉じる" />
    </Grid>
</Window>
